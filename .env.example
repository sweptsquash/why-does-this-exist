# ============================================
# Required Configuration
# ============================================

# Anthropic API key for AI explanations
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Optional Configuration
# ============================================

# GitHub token for private repos (public repos work without it)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ============================================
# Advanced Configuration (Optional)
# ============================================

# GitHub API Configuration
# GITHUB_API_BASE=https://api.github.com       # GitHub API base URL (for GitHub Enterprise)
# WDE_USER_AGENT=wde-cli                        # User agent for GitHub requests
# WDE_GITHUB_PER_PAGE=100                       # Items per page for GitHub API
# WDE_GITHUB_BATCH_SIZE=5                       # Concurrent issue fetch batch size

# GitHub Comment Limits
# WDE_MAX_REVIEW_COMMENTS=10                    # Max code review comments to include
# WDE_MAX_PR_COMMENTS=10                        # Max PR conversation comments
# WDE_MAX_ISSUE_COMMENTS=5                      # Max issue comments per issue

# AI Configuration
# WDE_DEFAULT_MODEL=claude-sonnet-4-20250514   # Default Claude model
# WDE_MAX_RESPONSE_TOKENS=500                   # Max tokens for AI response

# Context Builder Configuration
# WDE_MAX_TOKENS=8000                          # Token budget for context
# WDE_CHARS_PER_TOKEN=4                        # Approx characters per token
# WDE_MAX_DIFF_LINES=150                       # Max diff lines to include
# WDE_MAX_LINKED_ISSUES=3                      # Max linked issues to fetch

# Output Configuration
# WDE_VERBOSE=false                            # Enable verbose output by default
